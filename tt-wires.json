{
  "version": 1,
  "name": "tt-wires",
  "documents": [
    {
      "name": "Wire Source",
      "description": "A source of the content from a wire service, specifying the source from which the wire is obtained e.g. AP, Ritzau, RSS feed, etc.",
      "declares": "tt/wire-source",
      "attributes": {
        "title": {},
        "uri": {
          "glob": [
            "wires://source/**"
          ]
        }
      }
    },
    {
      "name": "Wire Provider",
      "description": "A provider of the content from a wire service, specifying the creator of the wire. For example, AP is the wire source and the provider can be AP itself or Business Wire etc.",
      "declares": "tt/wire-provider",
      "attributes": {
        "title": {},
        "uri": {
          "glob": [
            "wires://provider/**"
          ]
        }
      },
      "links": [
        {"ref":"core://content-source/use"}
      ]
    },
    {
      "name": "Wire meta document",
      "description": "Document used to store background information on a wire",
      "declares": "tt/wire+meta",
      "links": [
        {"ref": "core://subject"}
      ]
    },
    {
      "name": "Wire",
      "description": "A newsitem from a wire service",
      "declares": "tt/wire",
      "links": [
        {"ref": "core://content-source"},
        {
          "ref": "core://subject",
          "attributes": {
            "uri": {
              "optional": true,
              "deprecated": {
                "label": "wire_subject_uri",
                "doc": "Unnecessary when we have the UUID"
              }
            }
          }
        },
        {
          "ref": "core://section",
          "maxCount": 1
        },
        {
          "name": "Source",
          "description": "A reference to the source of the content",
          "declares": {
            "rel": "source"
          },
          "count": 1,
          "attributes": {
            "uuid": {},
            "uri": {
              "glob": [
                "wires://source/**"
              ]
            },
            "title": {}
          }
        },
        {
          "name": "Provider",
          "description": "The party that has provided the information",
          "declares": {
            "rel": "provider"
          },
          "attributes": {
            "uuid": {},
            "uri": {
              "glob": [
                "wires://provider/**"
              ]
            },
            "title": {}
          }
        }
      ],
      "meta": [
        {
          "name": "Wire metadata",
          "description": "Core metadata properties for the wire article.",
          "declares": {
            "type": "tt/wire"
          },
          "count": 1,
          "attributes": {
            "role": {
              "enum": [
                "article",
                "pressrelease"
              ]
            }
          },
          "data": {
            "issued": {
              "name": "Issued timestamp for the content",
              "format": "RFC3339"
            },
            "firstCreated": {
              "name": "First created timestamp for the content",
              "format": "RFC3339",
              "optional": true
            },
            "embargo_until": {
              "name": "If present the wire must not be re-published before this time",
              "format": "RFC3339",
              "optional": true
            },
            "version": {
              "name": "Opaque version identifier from the source"
            },
            "copyright": {}
          }
        },
        {"ref": "tt://slugline"},
        {"ref": "core://newsvalue"},
        {"ref": "core://note"},
        {
          "ref": "core://translation-source",
          "maxCount": 1,
          "content": [
            {"ref": "tt://wire/text"},
            {"ref": "core://table"},
            {"ref": "core://ordered-list"},
            {"ref": "core://unordered-list"}
          ]
        }
      ],
      "content": [
        {"ref": "tt://wire/text"},
        {"ref": "core://image"},
        {"ref": "core://table"},
        {"ref": "core://ordered-list"},
        {"ref": "core://unordered-list"}
      ]
    }
  ],
  "enums": [
    {
      "declare": "tt://wire/text-roles",
      "values": {
        "heading-1": {},
        "heading-2": {},
        "preamble": {},
        "vignette": {}
      }
    }
  ],
  "content": [
    {
      "id": "tt://wire/text",
      "block": {
        "name": "Text block",
        "description": "A block of text content such as a heading, preamble, or vignette.",
        "declares": {
          "type": "core/text"
        },
        "attributes": {
          "role": {
            "enumReference": "tt://wire/text-roles",
            "optional": true
          }
        },
        "data": {
          "text": {
            "allowEmpty": true,
            "format": "html"
          }
        }
      }
    }
  ]
}
